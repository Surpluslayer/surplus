{
  "manifest_version": 3,
  "name": "surplus",
  "version": "0.4.0",
  "description": "Your surplus book, on the side. See your relationship workflows fire as you browse LinkedIn.",
  "action": { "default_title": "Open surplus book" },
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "scripting",
    "cookies",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://event.surpluslayer.com/*",
    "https://surplus-staging.up.railway.app/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "frame_ruleset", "enabled": true, "path": "rules.json" }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
