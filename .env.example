# --- Database (production / Fly) --------------------------------------------
# Neon Postgres connection string — must include ?sslmode=require
# DATABASE_URL=postgresql://USER:PASS@HOST/DBNAME?sslmode=require

# --- Provider selection -----------------------------------------------------
PROVIDER=unipile

# --- Unipile ---------------------------------------------------------------
# Per-tenant DSN : Unipile assigns this on signup. Looks like:
#   https://api6.unipile.com:13443
UNIPILE_DSN=

# Bearer token from your Unipile dashboard.
UNIPILE_API_KEY=

# Public URL Unipile redirects back to after LinkedIn auth (required for sign-in).
# Local dev with Vite: http://localhost:5173
# Production: https://your-domain.com
SURPLUS_BASE_URL=http://localhost:5173

# Optional: force session cookie Secure flag (default: off for http://
# SURPLUS_BASE_URL, on for https or when base URL is unset). Set to "false"
# only if you need cookies over plain HTTP with a non-standard base URL.
# SURPLUS_SESSION_COOKIE_SECURE=

# The Unipile account_id of the connected LinkedIn account that will be the
# sender for outreach. Get it from /api/v1/accounts after connecting LinkedIn
# in the Unipile dashboard.
UNIPILE_ACCOUNT_ID=

# HMAC-SHA256 secret for webhook verification.
# Header: 'x-unipile-signature: sha256=<hex>' (or 'x-signature').
UNIPILE_WEBHOOK_SECRET=

# Safety: keep DRY_RUN=true while developing. Flip to false ONLY when you
# want real LinkedIn invites to leave the box.
UNIPILE_DRY_RUN=true

# If false AND no UNIPILE_WEBHOOK_SECRET is set, the webhook route will
# accept unauthenticated payloads (dev/staging only). Default true.
UNIPILE_REQUIRE_SIGNATURE=true

# --- Prospecting (AI discovery) -------------------------------------------
# Two backends, picked in this order:
#   1. EXA_API_KEY set  → Exa neural search per source (preferred : cheaper,
#                          faster, structured profile URLs)
#   2. ANTHROPIC_API_KEY set → Claude + web_search (fallback)
#   3. Neither set      → falls back to the hand-curated mock pool at
#                          backend/data/prospect_pool.json (offline demo)
#
# When either backend is available, ANTHROPIC_API_KEY is still used for the
# ICP-gatekeeper judge step (Haiku batched call) : discovery and judging
# are independent. Setting both gives you Exa discovery + Claude judging.
EXA_API_KEY=
ANTHROPIC_API_KEY=

# Cap on candidates each source adapter is allowed to surface. The judge
# phase is one batched Haiku call per run regardless of pool size, so this
# mostly tunes discovery latency and output quality, not rate-limit
# exposure. Total post-merge max is roughly 3×this. Keep this comfortably
# above the free-preview quota (FREE_PROSPECTS=8 in the SPA) so the paywall
# always has a long blurred tail to show for unpaid users.
PROSPECTING_MAX_PER_SOURCE=25

# In-memory cache TTL (seconds) for prospect() output, keyed by ICP. Same
# ICP within this window returns instantly instead of re-running web_search.
# Set 0 to disable; pass ?fresh=true on /prospect for a one-off bypass.
PROSPECTING_CACHE_TTL=3600

# Hard wall-clock cap for each source adapter's fetch(). Anthropic
# web_search_20260209 is consistently slow (60-90s) from Railway EU
# West, so the cap is intentionally generous. Lower if you want partial
# results faster; raise if you're still seeing timeouts in logs.
PROSPECTING_ADAPTER_TIMEOUT=120

# Same idea for the batched ICP-judge Haiku call. On timeout we keep
# every surfaced candidate (fail-open; discovery self-filters already).
PROSPECTING_JUDGE_TIMEOUT=15

# --- Fly deploy / demo gate (DEPLOY_PREP.md §1) ------------------------------
# DEMO_ACCESS_TOKEN=
# ADMIN_TOKEN=
# Phase 4 (access, monitoring, resilience) — all optional; behaviour is
# unchanged until set. See docs/SECURITY_CHECKLIST_ASSESSMENT.md (Phase 4).
#   ADMIN_READONLY_TOKEN : a least-privilege admin token that can reach ONLY
#     read-only endpoints (e.g. GET /admin/audit-log) — never a mutating one.
#     Provision monitors/dashboards with this instead of ADMIN_TOKEN.
#   ADMIN_IP_ALLOWLIST : comma-separated IPs/CIDRs the admin surface is pinned
#     to (a network second factor). Unset = open (default). Fails closed when
#     set (an unidentifiable caller IP is denied).
# ADMIN_READONLY_TOKEN=
# ADMIN_IP_ALLOWLIST=

# --- Billing (Stripe) --------------------------------------------------------
# Pick ONE of two integration patterns :
#
#   A) Payment Link (simplest, recommended)
#      Create a Payment Link in the Stripe dashboard (Products → click your
#      price → Create payment link). Paste the resulting URL here. No
#      server-side API call to create checkout sessions : the SPA redirects
#      directly to the Stripe-hosted page, with client_reference_id +
#      prefilled_email appended so the webhook can locate the user.
# STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_...
#
#   B) Checkout Session via API (more flexible, more setup)
#      Set STRIPE_PRICE_ID (price_... from Products page). Backend creates
#      a Checkout Session per call. Use this when you want per-session
#      customization (line items, discounts, line-item metadata).
# STRIPE_PRICE_ID=price_...
#
# Either way, both of the below are required for the webhook handler :
#
# STRIPE_SECRET_KEY     : Server-side secret. sk_test_... for staging,
#                         sk_live_... for prod. Generate at
#                         https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET : whsec_... from `stripe listen --forward-to
#                         http://localhost:8000/api/billing/webhook` for
#                         local dev. For deploys, create a webhook in
#                         the Stripe dashboard pointed at /api/billing/webhook
#                         and copy the signing secret it gives you.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# DEV-ONLY : set to "1" to enable POST /api/billing/dev/toggle-paid for
# local QA. Lets you flip paid_at on the signed-in user without going
# through Stripe Checkout. The endpoint returns 404 when this is unset,
# so leaving it unset in prod is the safe default.
# SURPLUS_DEV_BILLING=1

# ============================================================================
# AUTH (decoupled login) + OAuth CONNECTORS
# ============================================================================
# State signer for OAuth + email verify/reset tokens. Set a long random string
# in any real env (falls back to a dev default locally). Generate:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SURPLUS_OAUTH_STATE_SECRET=

# --- Encryption at rest (application-level field encryption) ----------------
# Key-encryption key (KEK) for backend/crypto.py. When set, OAuth access/refresh
# tokens are encrypted at rest with a per-tenant DEK (and existing plaintext
# rows are backfill-encrypted on next boot). UNSET = tokens stay plaintext (the
# app still works; encryption is simply off). This is the v1 stand-in for a
# KMS/HSM -- move it into a real KMS by editing crypto._load_kek. Generate:
#   openssl rand -base64 32     (or any random string >= 32 chars)
SURPLUS_ENCRYPTION_KEK=

# --- Database TLS -----------------------------------------------------------
# libpq sslmode for the app<->Postgres connection (Postgres/prod only; ignored
# for local SQLite). Defaults to `require` (encrypt the hop). Use `verify-full`
# + a CA for the strongest posture, or `disable` as an escape hatch if a deploy
# genuinely can't negotiate SSL.
# DB_SSLMODE=require

# --- Data retention (scheduled purge of ephemeral rows) ---------------------
# The category-TTL purge (backend/retention.run_purge_sweep, exposed at
# POST /admin/run-retention-purge) is OFF until enabled, and only ever deletes
# EPHEMERAL rows (expired/revoked sessions, old finished jobs) -- never contact
# or message content (that's retained while active, removed at offboarding via
# DELETE /api/me). Set the periods to your retention schedule before enabling.
# SURPLUS_RETENTION_ENABLED=1
# SURPLUS_RETENTION_SESSION_DAYS=90
# SURPLUS_RETENTION_JOB_DAYS=30

# --- Google (Sign in with Google + auto-connect Calendar + Contacts) --------
# Google Cloud Console: enable Calendar API + People API (NOT Gmail -- Gmail
# comes via Unipile to avoid CASA). Create a Web OAuth client; add redirect URIs:
#   {BASE}/api/auth/google/callback   AND   {BASE}/api/integrations/google/callback
# for each host (localhost + your domains). REQUIRED for Google login/connect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend (transactional email: the 6-digit verify PIN + password reset) --
# resend.com -> API key. Free tier (~3k/mo). Until set, those emails are dormant
# (signup/login still work). REQUIRED to actually send the PIN/reset emails.
RESEND_API_KEY=
# From-address. A VERIFIED Resend domain is required to email arbitrary users;
# without one you may only email your own account address (fine for testing).
SURPLUS_FROM_EMAIL=surplus <onboarding@resend.dev>

# --- OPTIONAL connectors (each lights up only its feature) -------------------
# Microsoft (Sign in with Microsoft + Outlook mail/calendar). Azure AD app;
# Graph perms Mail.Read + Calendars.ReadWrite + User.Read + offline_access.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# Zoom (create-meeting on bookings; Google Meet / Teams is the default).
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# Calendly (share scheduling link).
# CALENDLY_CLIENT_ID=
# CALENDLY_CLIENT_SECRET=
